{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "python",
      "package-name": "termiclaw",
      "changelog-path": "CHANGELOG.md",
      "pull-request-header": "## Installation\n\n```bash\nuv venv && uv pip install termiclaw==${version}\n```\n\n## Update\n\n```bash\nuv pip install --upgrade termiclaw\n```",
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ]
    }
  }
}
